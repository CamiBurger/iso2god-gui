{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ISO to GOD Converter",
  "version": "0.1.0",
  "identifier": "com.iso2godgui.converter",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ISO to GOD Converter",
        "width": 560,
        "height": 480,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/iso2god"
    ]
  }
}
